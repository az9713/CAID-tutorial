# Copy this file to `.env` and fill in your credentials.
# run_infer.py loads it automatically (via python-dotenv) before reading os.environ,
# and the values are inherited by the PaperBench judge subprocess too.

# ---- Required: LLM credentials (OpenAI-compatible) ----
# OpenAI direct is the simplest choice: it serves both the agent (via LiteLLM)
# and the judge (which is OpenAI-native) with one key.
LLM_API_KEY=sk-your-openai-key-here
LLM_BASE_URL=https://api.openai.com/v1

# ---- Model selection ----
# Agent model id. For OpenAI direct use the `openai/` prefix (LiteLLM routing).
LLM_MODEL=openai/gpt-4o-mini
# Optional: separate model for engineer subagents (defaults to LLM_MODEL).
# LLM_SUBAGENT_MODEL=openai/gpt-4o-mini

# ---- PaperBench judge ----
# MUST point at the judge venv's Python (separate from the main project venv,
# because the judge's deps conflict with the pinned project deps and need the
# Windows `resource` shim). Without this, the judge subprocess would use the
# main venv and fail to import paperbench.
JUDGE_PYTHON=C:/Users/simon/Downloads/CAID_cmu/frontier-evals/.judge-venv/Scripts/python.exe

# ---- Workspace ----
# run_infer.py unconditionally os.chdir()s here before building the Docker
# workspace. PaperBench uses the pre-built DockerWorkspace image, so this only
# needs to be any existing directory (the repo root is fine).
SDK_SOURCE_DIR=C:/Users/simon/Downloads/CAID_cmu

# Note: pass --judge_model gpt-4o-mini on the command line (the judge calls
# OpenAI directly, so it wants the bare model id without the openai/ prefix).
